{
  "name": "warpweb",
  "version": "1.0.0",
  "description": "Multi-column social media aggregator with BrowserView",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --inspect",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^25.1.8",
    "marked": "^12.0.0"
  },
  "build": {
    "appId": "com.warpweb.app",
    "productName": "WarpWeb",
    "publish": null,
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network",
      "maintainer": "WarpWeb <warpweb@example.com>"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "author": "WarpWeb <warpweb@t-online.de>",
  "homepage": "https://github.com/aotto1968/warpweb/",
  "license": "MIT"
}
